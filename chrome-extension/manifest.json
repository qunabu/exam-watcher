{
  "manifest_version": 3,
  "name": "info-kierowca session keeper + slot watcher",
  "version": "1.2.0",
  "description": "Keeps you logged in to info-kierowca.pl and watches for PORD Gdańsk/Gdynia practice exam slots — desktop popup + ntfy push when one appears.",
  "permissions": ["tabs", "alarms", "storage", "notifications"],
  "host_permissions": ["https://info-kierowca.pl/*", "https://ntfy.sh/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://info-kierowca.pl/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_title": "info-kierowca session keeper + slot watcher"
  },
  "icons": {}
}
